{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Plantasonic dark theme — default instrument palette (Figma Theme 1).",
  "color": {
    "primary": {
      "default": { "$type": "color", "$value": "{color.green.500}" },
      "hover": { "$type": "color", "$value": "#4dff89" },
      "pressed": { "$type": "color", "$value": "#00cc46" },
      "disabled": { "$type": "color", "$value": "#333333" }
    },
    "secondary": { "$type": "color", "$value": "#4dff89" },
    "accent": { "$type": "color", "$value": "#4dff89" },
    "surface": {
      "default": { "$type": "color", "$value": "{color.surface.app}" },
      "app": { "$type": "color", "$value": "{color.green.900}" },
      "stage": { "$type": "color", "$value": "{color.neutral.black}" },
      "nav": { "$type": "color", "$value": "#101c15" },
      "dock": { "$type": "color", "$value": "#101c15" },
      "input": { "$type": "color", "$value": "{color.neutral.800}" },
      "card": { "$type": "color", "$value": "#101c15" },
      "raised": { "$type": "color", "$value": "{color.neutral.900}" },
      "raised-hover": { "$type": "color", "$value": "#182b20" },
      "sunken": { "$type": "color", "$value": "#050a07" },
      "overlay": { "$type": "color", "$value": "{color.surface.input}" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "{color.green.700}" },
      "secondary": { "$type": "color", "$value": "{color.neutral.100}" },
      "muted": { "$type": "color", "$value": "{color.neutral.400}" },
      "accent": { "$type": "color", "$value": "#4dff89" },
      "link": { "$type": "color", "$value": "{color.accent}" },
      "inverse": { "$type": "color", "$value": "{color.neutral.100}" },
      "on-primary": { "$type": "color", "$value": "#070f0a" },
      "on-secondary": { "$type": "color", "$value": "#070f0a" },
      "on-accent": { "$type": "color", "$value": "#070f0a" }
    },
    "border": {
      "default": { "$type": "color", "$value": "rgba(255, 255, 255, 0.14)" },
      "subtle": { "$type": "color", "$value": "rgba(255, 255, 255, 0.08)" },
      "strong": { "$type": "color", "$value": "{color.neutral.white}" },
      "interactive": { "$type": "color", "$value": "#4dff89" },
      "focus": { "$type": "color", "$value": "#4dff89" }
    },
    "overlay": {
      "backdrop": { "$type": "color", "$value": "rgba(0, 0, 0, 0.65)" },
      "scrim-light": { "$type": "color", "$value": "rgba(255, 255, 255, 0.08)" },
      "scrim": { "$type": "color", "$value": "{color.overlay.scrim-light}" },
      "scrim-strong": { "$type": "color", "$value": "rgba(255, 255, 255, 0.12)" },
      "glass": { "$type": "color", "$value": "rgba(7, 15, 10, 0.85)" },
      "focus-outline": { "$type": "color", "$value": "rgba(255, 255, 255, 0.45)" }
    },
    "status": {
      "error-surface": { "$type": "color", "$value": "rgba(180, 40, 40, 0.92)" },
      "error-border": { "$type": "color", "$value": "rgba(255, 255, 255, 0.15)" }
    }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": "none" },
    "sm": { "$type": "shadow", "$value": "0 4px 12px rgba(0, 255, 87, 0.08)" },
    "md": { "$type": "shadow", "$value": "0 8px 24px rgba(0, 255, 87, 0.10)" },
    "lg": { "$type": "shadow", "$value": "0 16px 48px rgba(0, 255, 87, 0.12)" },
    "focus": { "$type": "shadow", "$value": "0 0 0 0.2rem rgba(77, 255, 137, 0.35)" },
    "glow-accent": { "$type": "shadow", "$value": "0 0 24px rgba(77, 255, 137, 0.35)" },
    "stage-inset": { "$type": "shadow", "$value": "inset 0 0 48px rgba(0, 0, 0, 0.65)" }
  },
  "product": {
    "nav-height": { "$type": "dimension", "$value": "3.5rem" },
    "dock-height": { "$type": "dimension", "$value": "4.5rem" },
    "sidebar-width": { "$type": "dimension", "$value": "18rem" },
    "touch-target": { "$type": "dimension", "$value": "2.75rem" },
    "overlay-radius": { "$type": "dimension", "$value": "{radius.xl}" },
    "preset-card-radius": { "$type": "dimension", "$value": "{radius.default}" },
    "preset-card-border": { "$type": "color", "$value": "{color.border.default}" },
    "preset-card-active-border": { "$type": "color", "$value": "{color.border.focus}" },
    "slider-track": { "$type": "color", "$value": "{color.surface.input}" },
    "slider-thumb": { "$type": "color", "$value": "{color.primary.default}" },
    "stage-border": { "$type": "color", "$value": "{color.border.default}" },
    "performance-chrome-opacity": { "$type": "number", "$value": 0.92 },
    "shadow-overlay": { "$type": "shadow", "$value": "0 16px 48px rgba(0, 0, 0, 0.65)" },
    "shadow-sidebar": { "$type": "shadow", "$value": "4px 0 24px rgba(0, 0, 0, 0.4)" },
    "shadow-panel": { "$type": "shadow", "$value": "{product.shadow-overlay}" }
  }
}
