{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Plantasonic foundation primitives — theme-agnostic values shared by all themes.",
  "color": {
    "green": {
      "500": { "$type": "color", "$value": "#00ff57" },
      "700": { "$type": "color", "$value": "#4dff89" },
      "900": { "$type": "color", "$value": "#070f0a" }
    },
    "neutral": {
      "100": { "$type": "color", "$value": "#e5e5e5" },
      "200": { "$type": "color", "$value": "#cccccc" },
      "300": { "$type": "color", "$value": "#b2b2b2" },
      "400": { "$type": "color", "$value": "#999999" },
      "500": { "$type": "color", "$value": "#808080" },
      "600": { "$type": "color", "$value": "#666666" },
      "700": { "$type": "color", "$value": "#4d4d4d" },
      "800": { "$type": "color", "$value": "#333333" },
      "900": { "$type": "color", "$value": "#1a1a1a" },
      "white": { "$type": "color", "$value": "#ffffff" },
      "black": { "$type": "color", "$value": "#000000" }
    },
    "status": {
      "success": { "$type": "color", "$value": "#00ff57" },
      "warning": { "$type": "color", "$value": "#f5c542" },
      "error": { "$type": "color", "$value": "#ff5c5c" },
      "info": { "$type": "color", "$value": "#4dff89" }
    },
    "decorative": {
      "favorite": { "$type": "color", "$value": "#f5c542" }
    }
  },
  "gradient": {
    "light": {
      "$type": "color",
      "$value": "linear-gradient(136deg, #00ff57 0%, #ffffff 100%)"
    },
    "dark": {
      "$type": "color",
      "$value": "linear-gradient(136deg, #00ff57 0%, #070f0a 100%)"
    }
  },
  "font": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Inter", "system-ui", "-apple-system", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"]
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "ui-monospace", "Cascadia Code", "monospace"]
      }
    },
    "size": {
      "base": { "$type": "dimension", "$value": "1rem" },
      "display": { "$type": "dimension", "$value": "2.5rem" },
      "h1": { "$type": "dimension", "$value": "2rem" },
      "h2": { "$type": "dimension", "$value": "1.5rem" },
      "h3": { "$type": "dimension", "$value": "1.25rem" },
      "h4": { "$type": "dimension", "$value": "1.125rem" },
      "body": { "$type": "dimension", "$value": "1rem" },
      "body-sm": { "$type": "dimension", "$value": "0.875rem" },
      "caption": { "$type": "dimension", "$value": "0.75rem" },
      "label": { "$type": "dimension", "$value": "0.875rem" },
      "overline": { "$type": "dimension", "$value": "0.6875rem" }
    },
    "line-height": {
      "base": { "$type": "number", "$value": 1.5 },
      "tight": { "$type": "number", "$value": 1.1 },
      "body": { "$type": "number", "$value": 1.4 },
      "relaxed": { "$type": "number", "$value": 1.6 }
    },
    "weight": {
      "body": { "$type": "fontWeight", "$value": 400 },
      "headings": { "$type": "fontWeight", "$value": 600 },
      "label": { "$type": "fontWeight", "$value": 600 },
      "mono": { "$type": "fontWeight", "$value": 500 }
    },
    "letter-spacing": {
      "label": { "$type": "dimension", "$value": "0.08em" },
      "overline": { "$type": "dimension", "$value": "0.08em" },
      "caption": { "$type": "dimension", "$value": "0.04em" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "1rem" },
    "4": { "$type": "dimension", "$value": "1.5rem" },
    "5": { "$type": "dimension", "$value": "2rem" },
    "6": { "$type": "dimension", "$value": "3rem" },
    "8": { "$type": "dimension", "$value": "4rem" },
    "12": { "$type": "dimension", "$value": "0.75rem" },
    "20": { "$type": "dimension", "$value": "1.25rem" },
    "28": { "$type": "dimension", "$value": "1.75rem" },
    "36": { "$type": "dimension", "$value": "2.25rem" },
    "40": { "$type": "dimension", "$value": "2.5rem" },
    "44": { "$type": "dimension", "$value": "2.75rem" },
    "52": { "$type": "dimension", "$value": "3.25rem" },
    "56": { "$type": "dimension", "$value": "3.5rem" },
    "60": { "$type": "dimension", "$value": "3.75rem" },
    "68": { "$type": "dimension", "$value": "4.25rem" },
    "72": { "$type": "dimension", "$value": "4.5rem" },
    "999": { "$type": "dimension", "$value": "62.4375rem" }
  },
  "radius": {
    "xs": { "$type": "dimension", "$value": "0.125rem" },
    "sm": { "$type": "dimension", "$value": "0.25rem" },
    "default": { "$type": "dimension", "$value": "0.5rem" },
    "lg": { "$type": "dimension", "$value": "1rem" },
    "xl": { "$type": "dimension", "$value": "1.5rem" },
    "pill": { "$type": "dimension", "$value": "62.4375rem" }
  },
  "transition": {
    "fast": { "$type": "duration", "$value": "150ms" },
    "base": { "$type": "duration", "$value": "250ms" },
    "slow": { "$type": "duration", "$value": "400ms" }
  },
  "ease": {
    "out": { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
    "in": { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
    "in-out": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
  }
}
